---
type Props = {
  items: string[];
  updated: string; // e.g., "April 2026"
  index?: string; // optional section number, e.g. "01"
};

const { items, updated, index } = Astro.props;
---

<section id="currently" class="py-12 sm:py-16 border-t border-[var(--color-rule)]">
  <p class="eyebrow">{index ? `${index} / Now` : "Now"}</p>
  <h2 class="mt-3 text-2xl sm:text-[1.75rem] font-semibold tracking-tight">
    Currently
  </h2>

  <ul class="mt-6 space-y-3 max-w-[62ch]">
    {items.map((item) => (
      <li class="flex gap-3 leading-relaxed text-[var(--color-fg)]">
        <span aria-hidden="true" class="mt-[0.55em] inline-block w-3 h-px bg-[var(--color-rule-strong)] shrink-0"></span>
        <span set:html={item} />
      </li>
    ))}
  </ul>

  <p class="mt-6 text-xs text-[var(--color-faint)]">
    Last updated · {updated}
  </p>
</section>
