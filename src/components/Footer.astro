---
import { SITE } from "~/lib/meta.ts";

const year = new Date().getFullYear();
---

<footer
  data-site-footer
  class="w-full border-t border-[var(--color-rule)] mt-20"
>
  <div class="mx-auto max-w-3xl px-5 sm:px-6 lg:px-8 py-10 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between text-sm text-[var(--color-muted)]">
    <div class="flex flex-col gap-1">
      <p class="text-[var(--color-fg)] font-medium">{SITE.name}</p>
      <p class="text-[var(--color-subtle)]">Remote · CET ±2 · based in Iran</p>
      <p class="text-[var(--color-faint)] text-xs mt-1">© {year} · Built with Astro</p>
    </div>

    <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
      <li>
        <a href={`mailto:${SITE.email}`} class="no-underline hover:underline">
          Email
        </a>
      </li>
      <li>
        <a
          href={SITE.github}
          target="_blank"
          rel="noopener"
          class="no-underline hover:underline"
        >
          GitHub
        </a>
      </li>
      <li>
        <a
          href={SITE.linkedin}
          target="_blank"
          rel="noopener"
          class="no-underline hover:underline"
        >
          LinkedIn
        </a>
      </li>
      <li>
        <a href="/cv.pdf" class="no-underline hover:underline">
          CV
        </a>
      </li>
      <li>
        <a href="/rss.xml" class="no-underline hover:underline">
          RSS
        </a>
      </li>
    </ul>
  </div>
</footer>
