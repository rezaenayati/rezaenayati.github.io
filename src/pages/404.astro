---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="Page not found.">
  <section class="pt-24 pb-20 text-center">
    <p class="eyebrow">Error · 404</p>
    <h1 class="mt-5 text-3xl sm:text-[2.5rem] leading-[1.1] font-semibold tracking-tight">
      Nothing here.
    </h1>
    <p class="mt-4 text-[var(--color-muted)]">
      Try the <a href="/">home page</a>, or jump to the
      <a href="/case-studies/">case studies</a>.
    </p>
  </section>
</BaseLayout>
