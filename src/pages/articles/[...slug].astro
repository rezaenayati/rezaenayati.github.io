---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Prose from "~/components/Prose.astro";
import { SITE, articleSchema } from "~/lib/meta.ts";

export async function getStaticPaths() {
  const isProd = import.meta.env.PROD;
  const entries = await getCollection("articles", ({ data }) =>
    isProd ? !data.draft : true,
  );
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"articles"> };

const { entry } = Astro.props;
const { Content } = await entry.render();

const updatedDate = entry.data.updatedAt ?? entry.data.publishedAt;
const updatedLabel = new Date(updatedDate).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});

const ogImage = `/og/articles/${entry.slug}.png`;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();

const jsonLd = articleSchema({
  title: entry.data.title,
  description: entry.data.summary,
  url: canonical,
  publishedAt: entry.data.publishedAt,
  updatedAt: entry.data.updatedAt,
  image: new URL(ogImage, SITE.url).toString(),
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  type="article"
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <article class="pt-10 pb-6">
    <p class="text-sm">
      <a href="/articles/" class="no-underline hover:underline text-[var(--color-muted)] hover:text-[var(--color-fg)]">
        ← All writing
      </a>
    </p>

    <header class="mt-10 mb-10">
      <p class="eyebrow">Note</p>

      <h1 class="mt-4 text-3xl sm:text-[2.5rem] leading-[1.1] font-semibold tracking-tight">
        {entry.data.title}
      </h1>

      <p class="mt-5 text-sm text-[var(--color-subtle)] flex flex-wrap items-center gap-x-2 gap-y-1">
        {entry.data.tags.map((t, i) => (
          <>
            {i > 0 && <span aria-hidden="true" class="text-[var(--color-faint)]">·</span>}
            <span>{t}</span>
          </>
        ))}
        <span aria-hidden="true" class="text-[var(--color-faint)]">·</span>
        <span>{entry.data.readingTime} read</span>
        <span aria-hidden="true" class="text-[var(--color-faint)]">·</span>
        <span>Updated {updatedLabel}</span>
      </p>

      <p class="mt-6 italic text-[var(--color-muted)] leading-relaxed border-l-2 border-[var(--color-rule-strong)] pl-4 max-w-[68ch]">
        {entry.data.summary}
      </p>
    </header>

    <Prose>
      <Content />
    </Prose>

    <hr class="mt-14" />

    <nav class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <a href="/articles/" class="no-underline hover:underline text-[var(--color-muted)] hover:text-[var(--color-fg)]">
        ← All writing
      </a>
      <a href="/" class="no-underline hover:underline text-[var(--color-muted)] hover:text-[var(--color-fg)]">
        ← Home
      </a>
    </nav>
  </article>
</BaseLayout>
